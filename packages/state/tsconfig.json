{
  "compilerOptions": {
    "target": "es2023",
    // DOM is included only for host-provided timer types (setTimeout/clearTimeout
    // in fxStore); the stores themselves never touch document/window — those web
    // concerns live behind the injected ports. RN provides the same timers.
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": [],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
