{
  "name": "sudoku",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @sudoku/web dev",
    "build": "turbo run build",
    "preview": "pnpm --filter @sudoku/web preview",
    "test": "turbo run test",
    "test:all": "turbo run test",
    "test:fast": "turbo run test:fast",
    "test:ui": "pnpm --filter @sudoku/web test:ui",
    "test:coverage": "pnpm --filter @sudoku/web test:coverage",
    "test:visual": "pnpm --filter @sudoku/web test:visual",
    "test:gestures": "pnpm --filter @sudoku/web test:gestures",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "gen:challenges": "pnpm --filter @sudoku/web gen:challenges",
    "gen:lessons": "pnpm --filter @sudoku/web gen:lessons"
  },
  "devDependencies": {
    "turbo": "^2.10.4"
  }
}
